# Pranadatha — Client Environment Variables
# Copy this to .env and update for your environment
# NEVER commit the actual .env file to Git!

# Backend API URL
# - Development: http://localhost:5000/api
# - Production: https://pranadatha-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# VAPID Public Key (same as server VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
