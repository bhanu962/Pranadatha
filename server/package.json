{
  "name": "blood-donor-finder-server",
  "version": "1.0.0",
  "description": "Blood Donor Finder REST API - Node.js/Express backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "generate-vapid": "node scripts/generateVapid.js",
    "logs:make": "node -e \"require('fs').mkdirSync('../logs',{recursive:true})\""
  },
  "keywords": [
    "blood-donation",
    "nodejs",
    "express",
    "mongodb",
    "pwa",
    "web-push"
  ],
  "author": "Blood Donor Finder",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  },
  "devDependencies": {
    "jimp": "^1.6.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.14",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0"
  }
}
