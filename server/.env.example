# Pranadatha — Server Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git!

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/blood-donor-finder?appName=Pranadatha

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRE=7d

# ── VAPID Keys (Web Push Notifications) ──────────────────────────────────────
# Generate with: node scripts/generateVapid.js
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=your@email.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ── Client URL (used in email links) ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
FROM_EMAIL=noreply@pranadatha.in
FROM_NAME=Pranadatha

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
