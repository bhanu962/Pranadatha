# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/blood-donor-finder

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32chars
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this
JWT_EXPIRE=7d

# VAPID Keys for Web Push Notifications
# Generate with: node server/scripts/generateVapid.js
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@yourdomain.com

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173

# Logging Level: error | warn | info | http | verbose | debug
LOG_LEVEL=info

# Email (optional - for future email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── Client ──────────────────────────────────────────────────────────────────
# Copy these to client/.env
VITE_API_URL=/api
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VITE_MAP_TILE_KEY=optional_mapbox_or_stadia_key
